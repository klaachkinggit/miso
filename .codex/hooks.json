{
  "_comment": "Codex CLI hooks. Scripts are vendored under .codex/hooks and read tool input JSON on stdin. They exit 2 to block dangerous actions.",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Done\" with title \"Codex\"' 2>/dev/null || echo -n $'\\a'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^Edit$|^Write$|^Read$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/protect-secrets.sh\""
          }
        ]
      },
      {
        "matcher": "^Bash$|^Shell$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/block-dangerous.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/log-bash.sh\""
          }
        ]
      },
      {
        "matcher": "^mcp__github__create_pull_request$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/pre-pr-gate.sh\"",
            "timeout": 120
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^Edit$|^Write$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/auto-format.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}

{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Edit$|^MultiEdit$|^NotebookEdit$|^Write$|^Bash$|^Shell$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/protect-env.sh\""
          }
        ]
      }
    ]
  }
}

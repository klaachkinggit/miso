# ============================================================================
# Miso — On-Chain Implementation (Base Sepolia via Thirdweb)
# Copy this file to .env and fill values.
#
# Quick start:
#   cp .env.example .env
#   supabase start
#   supabase migration up         # or `supabase db reset`
#   npm run demo:seed             # creates demo admin/buyer/controller + event
#   npm run dev                   # http://localhost:3002
# ============================================================================

# --- Supabase ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --- Thirdweb (Base Sepolia) ------------------------------------------------
# Dashboard: https://thirdweb.com/team
# Auth: secret key in `x-secret-key` header; backend wallet in
# `x-backend-wallet-address` header. NEVER commit the secret key.
THIRDWEB_CLIENT_ID=
THIRDWEB_SECRET_KEY=
THIRDWEB_API_URL=https://api.thirdweb.com
THIRDWEB_BACKEND_WALLET_ADDRESS=0x1860Ef4CdB6EFf2E06C9D3cC4b6530eb2822bAC5

# --- Chain ------------------------------------------------------------------
# Base Sepolia: 84532. Base mainnet (future): 8453.
CHAIN_ID=84532
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_EXPLORER_BASE=https://sepolia.basescan.org

# --- Stripe -----------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MISO_PRIMARY_PLATFORM_FEE_PERCENT=4
MISO_PRIMARY_PLATFORM_FEE_FIXED=0
MISO_STRIPE_FEE_PERCENT=1.5
MISO_STRIPE_FEE_FIXED=0.25

# --- Live-chain test gate ---------------------------------------------------
# Set to "true" to enable the live Sepolia smoke test. Off by default.
LIVE_CHAIN=false

# --- App --------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3002

# Stripe marketplace (separate charges and transfers)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Platform marketplace fee in basis points (500 = 5%)
MISO_MARKETPLACE_FEE_BPS=500
# Signing secret for the marketplace webhook endpoint (/api/stripe-marketplace/webhook).
# Separate registered endpoint in Stripe => separate whsec_. Falls back to
# STRIPE_WEBHOOK_SECRET when unset (single-endpoint dev).
STRIPE_MARKETPLACE_WEBHOOK_SECRET=

# Vercel Cron auth — settlement re-drive + Stripe reconciliation sweeps.
CRON_SECRET=

# Sentry error monitoring (production observability — P0.4).
# All inits are DSN-gated: leave these unset locally/CI for a clean no-op.
SENTRY_DSN=                 # Server + edge DSN (runtime; instrumentation.ts)
NEXT_PUBLIC_SENTRY_DSN=     # Browser DSN (runtime; instrumentation-client.ts)
SENTRY_AUTH_TOKEN=          # Source-map upload at build time only (gates withSentryConfig uploads)
SENTRY_ORG=                 # Sentry org slug (source-map upload)
SENTRY_PROJECT=             # Sentry project slug (source-map upload)

# --- Transactional email (Resend + react-email) ---
RESEND_API_KEY=            # Resend API key; UNSET disables all email (send is a no-op)
EMAIL_FROM=                # Verified sender, e.g. "Miso <tickets@miso.example>" — domain must pass SPF/DKIM/DMARC
EMAIL_REPLY_TO=            # Optional Reply-To address for transactional mail

# Upstash Redis REST — rate limiting (checkout/auth/onboarding/listing).
# Unset = no-op (local/CI run unthrottled). Fail-open on Redis errors.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

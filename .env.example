# ============================================================================
# Miso — NFT Ticketing MVP
# Copy this file to .env.local and fill values.
#
# Quick start for the full free demo (no real money, no real APIs):
#   cp .env.example .env.local
#   pnpm airdrop                # generates PLATFORM_TREASURY_SECRET on devnet
#   supabase start
#   supabase migration up       # or `supabase db reset`
#   pnpm demo:seed              # creates demo admin/buyer/controller + event
#   pnpm dev
# ============================================================================

# --- Supabase ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --- Wallet encryption ------------------------------------------------------
# Generate with:  openssl rand -base64 32
# MUST be 32 raw bytes base64-encoded. Used for AES-256-GCM custodial keys.
# MVP-ONLY: production must use Turnkey/Privy/Magic. See lib/solana/wallet.ts.
WALLET_ENCRYPTION_KEY=

# --- Solana -----------------------------------------------------------------
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_EXPLORER_BASE=https://explorer.solana.com
# Treasury wallet (platform-owned, used for refunds & escrow). Base58 secret key.
# Generated by `pnpm airdrop` the first time.
PLATFORM_TREASURY_SECRET=

# --- Demo mode --------------------------------------------------------------
# When true, skip real Solana mint + use MockPaymentProvider.
MISO_DEMO_MODE=true

# --- Payments ---------------------------------------------------------------
# mock = MockPaymentProvider (free demo, fulfills inline, no network).
# payzone = PayzoneProvider (production HPP integration; needs creds below).
PAYMENT_PROVIDER=mock

# Required only when PAYMENT_PROVIDER=payzone.
PAYZONE_API_BASE=
PAYZONE_MERCHANT_ID=
PAYZONE_API_KEY=
PAYZONE_HMAC_SECRET=

# --- App --------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

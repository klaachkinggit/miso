# ============================================================================
# Miso — NFT Ticketing demo branch
# Copy this file to .env.local and fill values.
#
# Quick start (no real money, no real APIs, synthetic NFTs):
#   cp .env.example .env.local
#   supabase start
#   supabase migration up       # or `supabase db reset`
#   pnpm demo:seed              # creates demo admin/buyer/controller + event
#   pnpm dev
# ============================================================================

# --- Supabase ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --- Wallet encryption ------------------------------------------------------
# Generate with:  openssl rand -base64 32
# MUST be 32 raw bytes base64-encoded. Used for AES-256-GCM custodial keys.
# MVP-ONLY: production must use Turnkey/Privy/Magic. See lib/solana/wallet.ts.
WALLET_ENCRYPTION_KEY=

# --- Solana -----------------------------------------------------------------
# Used by external-wallet adapter UI and explorer links. Demo never makes
# on-chain calls (synthetic asset ids only).
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_EXPLORER_BASE=https://explorer.solana.com

# --- App --------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

{
  "name": "miso",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "seed": "tsx scripts/seed.ts",
    "demo:seed": "tsx scripts/seed.ts",
    "contracts:compile": "tsx scripts/compile-contracts.ts",
    "live:flow": "tsx scripts/live-flow.ts",
    "live:resale": "tsx scripts/live-resale.ts",
    "supabase:types": "supabase gen types typescript --local > src/types/db.ts",
    "test:unit": "vitest run",
    "test:all": "npm run typecheck && npm run lint && npm run test:unit && npm run test:e2e",
    "test:e2e:all-local": "MISO_MOCK_CHAIN=1 MISO_E2E_FULL=1 MISO_E2E_INVARIANTS=1 playwright test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@supabase/ssr": "^0.5.1",
    "@supabase/supabase-js": "^2.45.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.453.0",
    "next": "^15.5.18",
    "qrcode": "^1.5.4",
    "react": "^19.0.0-rc",
    "react-dom": "^19.0.0-rc",
    "server-only": "^0.0.1",
    "stripe": "^22.1.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "viem": "^2.21.45",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@next/env": "^15.5.18",
    "@openzeppelin/contracts": "^5.6.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.7.7",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.13.0",
    "eslint-config-next": "15.0.2",
    "postcss": "^8.4.47",
    "solc": "^0.8.35",
    "supabase": "^2.100.1",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.6"
  }
}
